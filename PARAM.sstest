Begin session: 1

#DESCRIPTION
PARAM.in: dipole steady state attempt for extreme	StringDescription

INCLUDE
RESTART.in

#COMPONENTMAP
SC 0 -1 1
IH 0 -1 1			NameComp

#TIMEACCURATE
F			IsTimeAccurate

#STARTTIME
2011			iYear
03			iMonth
07			iDay
08			iHour
00			iMinute
00			iSecond
0.0			FracSecond

#SAVERESTART
